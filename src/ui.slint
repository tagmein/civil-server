component OutlineButton inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 28px;
    background: #ffffff;
    border-radius: 2px;
    border-width: 1px;
    border-color: #bdbdbd;

    Text {
        text: parent.label;
        color: #000000;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    TouchArea { clicked => { parent.clicked(); } }
}

component QuitButton inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 28px;
    background: #c0392b;
    border-radius: 2px;
    border-width: 1px;
    border-color: #a93226;

    Text {
        text: parent.label;
        color: #ffffff;
        font-weight: 700;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    TouchArea { clicked => { parent.clicked(); } }
}

export component MainWindow inherits Window {
    title: " ";
    preferred-width: 240px;
    preferred-height: 360px;
    min-width: 240px;
    max-width: 240px;
    min-height: 360px;
    max-height: 360px;

    in-out property <string> statusText: "Status: Stopped";
    in-out property <color> statusColor: #000000;

    callback quit();
    callback startServer();
    callback stopServer();
    callback syncSessions();
    callback configuration();
    callback about();

    Text {
        x: 0px;
        y: 22px;
        width: root.width;
        height: 22px;
        text: "Civil Server";
        font-size: 16px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    Text {
        x: 0px;
        y: 52px;
        width: root.width;
        height: 18px;
        text: root.statusText;
        color: root.statusColor;
        horizontal-alignment: center;
    }

    OutlineButton {
        x: (root.width - 220px) / 2;
        y: 88px;
        width: 220px;
        label: "Start Server";
        clicked => { root.startServer(); }
    }

    OutlineButton {
        x: (root.width - 220px) / 2;
        y: 124px;
        width: 220px;
        label: "Stop Server";
        clicked => { root.stopServer(); }
    }

    OutlineButton {
        x: (root.width - 220px) / 2;
        y: 160px;
        width: 220px;
        label: "Sync Sessions";
        clicked => { root.syncSessions(); }
    }

    OutlineButton {
        x: (root.width - 220px) / 2;
        y: 196px;
        width: 220px;
        label: "Configuration";
        clicked => { root.configuration(); }
    }

    OutlineButton {
        x: (root.width - 220px) / 2;
        y: 232px;
        width: 220px;
        label: "About";
        clicked => { root.about(); }
    }

    QuitButton {
        x: (root.width - 220px) / 2;
        y: 322px;
        width: 220px;
        label: "Quit";
        clicked => { root.quit(); }
    }
}
