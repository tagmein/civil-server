import { LineEdit } from "std-widgets.slint";

export component ConfigDialog inherits Window {
    title: "Server Configuration";
    preferred-width: 450px;
    preferred-height: 280px;
    min-width: 450px;
    max-width: 450px;
    min-height: 280px;
    max-height: 280px;

    in-out property <string> portText;
    in-out property <string> commandText;
    in-out property <string> directoryText;

    callback saveConfig(string, string, string);
    callback closeDialog();

    Text {
        x: 0px;
        y: 22px;
        width: root.width;
        height: 22px;
        text: "Configuration";
        font-size: 18px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    Text {
        x: 20px;
        y: 60px;
        width: 80px;
        height: 18px;
        text: "Port:";
    }

    LineEdit {
        x: 100px;
        y: 58px;
        width: root.width - 120px;
        height: 24px;
        text <=> root.portText;
        placeholder-text: "e.g. 4567";
    }

    Text {
        x: 20px;
        y: 98px;
        width: 80px;
        height: 18px;
        text: "Command:";
    }

    LineEdit {
        x: 100px;
        y: 96px;
        width: root.width - 120px;
        height: 24px;
        text <=> root.commandText;
        placeholder-text: "e.g. node server.js";
    }

    Text {
        x: 20px;
        y: 136px;
        width: 80px;
        height: 18px;
        text: "Directory:";
    }

    LineEdit {
        x: 100px;
        y: 134px;
        width: root.width - 120px;
        height: 24px;
        text <=> root.directoryText;
        placeholder-text: "Full path to project";
    }

    Rectangle {
        x: (root.width - 200px) / 2;
        y: 200px;
        width: 90px;
        height: 28px;
        background: #ffffff;
        border-radius: 2px;
        border-width: 1px;
        border-color: #bdbdbd;

        Text {
            text: "Save Settings";
            color: #000000;
            vertical-alignment: center;
            horizontal-alignment: center;
        }

        TouchArea {
            clicked => {
                root.saveConfig(root.portText, root.commandText, root.directoryText);
                root.closeDialog();
            }
        }
    }

    Rectangle {
        x: (root.width - 200px) / 2 + 110px;
        y: 200px;
        width: 90px;
        height: 28px;
        background: #c0392b;
        border-radius: 2px;
        border-width: 1px;
        border-color: #a93226;

        Text {
            text: "Cancel";
            color: #ffffff;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: center;
        }

        TouchArea {
            clicked => { root.closeDialog(); }
        }
    }
}
